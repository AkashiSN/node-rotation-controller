{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "title": "node-rotation-controller values",
  "description": "Install-time validation of the chart values. The CRD's OpenAPI schema and the controller re-validate the rendered RotationPolicy at admission/reconcile time (spec §5.4) — this schema is a fast first line of defense, not the source of truth.",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "description": "v1 expects 2 for leader election (spec §5.1)."
    },
    "priorityClassName": {
      "type": "string",
      "description": "PriorityClass for the CONTROLLER Pod; empty means the cluster default priority. Unrelated to placeholder.priorityClass, the surge placeholder's negative-priority class (spec §3.3). PodSpec.priorityClassName is a string, so a bare `true` or `123` is rejected here rather than rendering an invalid Deployment."
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "tag": { "type": "string" }
      }
    },
    "placeholder": {
      "type": "object",
      "properties": {
        "image": { "type": "string", "minLength": 1 },
        "priorityClass": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 },
            "value": {
              "type": "integer",
              "maximum": -1,
              "description": "Must be negative so the placeholder is the preemption victim (spec §3.3)."
            }
          }
        }
      }
    },
    "prometheusRule": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "completedFailure": { "$ref": "#/definitions/alertTuning" },
        "candidatesNotDraining": {
          "allOf": [
            { "$ref": "#/definitions/alertTuning" },
            { "properties": { "windowRange": { "$ref": "#/definitions/promDuration" } } }
          ]
        },
        "stalledInWindow": {
          "allOf": [
            { "$ref": "#/definitions/alertTuning" },
            { "properties": { "completionRange": { "$ref": "#/definitions/promDuration" } } }
          ]
        },
        "drainStuck": { "$ref": "#/definitions/alertTuning" },
        "shortLeadNodes": { "$ref": "#/definitions/alertTuning" },
        "retryCountHigh": { "$ref": "#/definitions/alertTuning" },
        "forcefulFallback": { "$ref": "#/definitions/alertTuning" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": ["integer", "string"] }
      }
    },
    "rotationPolicies": {
      "type": "array",
      "description": "RotationPolicy objects (issue #153), one per entry. An empty list renders none, leaving you to author your own out-of-band.",
      "items": {
        "type": "object",
        "required": ["spec"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Cluster-scoped RotationPolicy name; must be unique across entries. Omit it to fall back to the chart fullname — only a single-entry list can rely on that."
          },
          "create": {
            "type": "boolean",
            "description": "Set false to skip just this entry (defaults true)."
          },
          "spec": { "$ref": "#/definitions/rotationPolicySpec" }
        }
      }
    }
  },
  "definitions": {
    "rotationPolicySpec": {
      "type": "object",
      "required": ["nodePoolSelector", "maintenanceWindows"],
      "additionalProperties": false,
      "properties": {
            "nodePoolSelector": {
              "type": "object",
              "minProperties": 1,
              "additionalProperties": false,
              "properties": {
                "matchLabels": {
                  "type": "object",
                  "minProperties": 1,
                  "additionalProperties": { "type": "string" }
                },
                "matchExpressions": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "required": ["key", "operator"],
                    "additionalProperties": false,
                    "properties": {
                      "key": { "type": "string", "minLength": 1 },
                      "operator": {
                        "type": "string",
                        "enum": ["In", "NotIn", "Exists", "DoesNotExist"]
                      },
                      "values": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              }
            },
            "ageThreshold": {
              "type": "string",
              "description": "\"auto\" or a Go duration (e.g. \"120h\")."
            },
            "minRotationChances": { "type": "integer", "minimum": 1 },
            "maintenanceWindows": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["timezone", "days", "start", "end"],
                "additionalProperties": false,
                "properties": {
                  "timezone": { "type": "string", "minLength": 1 },
                  "days": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "string",
                      "enum": ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
                    }
                  },
                  "start": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" },
                  "end": { "type": "string", "pattern": "^([01][0-9]|2[0-3]):[0-5][0-9]$" }
                }
              }
            },
            "surge": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxUnavailable": {
                  "const": 1,
                  "description": "v1 is surge-only and serial per NodePool (spec §5.4)."
                },
                "readyTimeout": { "$ref": "#/definitions/goDuration" },
                "cooldownAfter": {
                  "allOf": [{ "$ref": "#/definitions/goDurationNonNegative" }],
                  "description": "Post-success settle pause (gate A, spec §5.2) and a layer-2 throughput term (§3.2). May be 0 — PDBs are the primary settle (ADR-0004). Does not cover the post-failure pause (see failurePause)."
                },
                "failurePause": {
                  "allOf": [{ "$ref": "#/definitions/goDuration" }],
                  "description": "Pool-level inter-attempt pause after a FAILED attempt (gate B, spec §5.2/§4.4, ADR-0004). Bounds candidate cycling under a systematic failure cause. Unset resolves to max(10m, cooldownAfter). Must be positive."
                },
                "drainEstimate": {
                  "allOf": [{ "$ref": "#/definitions/goDuration" }],
                  "description": "Expected drain duration for the layer-2 throughput forecast (spec §3.2). Unset resolves to min(terminationGracePeriod, 10m). Not a bound — terminationGracePeriod remains the force-kill deadline."
                },
                "provisioningEstimate": {
                  "allOf": [{ "$ref": "#/definitions/goDuration" }],
                  "description": "Expected surge-provisioning duration (candidate → Ready) for the layer-2 throughput forecast (spec §3.2, ADR-0003). Unset resolves to min(readyTimeout, 5m). Not a bound — readyTimeout remains the deadline the surge attempt is abandoned at."
                },
                "retryBackoff": { "$ref": "#/definitions/goDuration" },
                "matchNodeRequirements": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "required": { "type": "array", "items": { "type": "string" } },
                    "preferred": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "forcefulFallback": {
                  "type": "object",
                  "additionalProperties": false,
                  "description": "Opt-in window-bounded surge-less forceful fallback (spec §3.3, ADR-0001). Default off.",
                  "properties": {
                    "enabled": {
                      "type": "boolean",
                      "description": "Rotate a candidate that cannot finish a graceful surge before its own deadline surge-less, in-window, via the voluntary (PDB-respecting) path."
                    }
                  }
                }
              }
            },
            "prePull": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "enabled": {
                  "const": false,
                  "description": "v2 feature; must be false in v1 (spec §5.4)."
                }
              }
            }
          }
    },
    "goDuration": {
      "type": "string",
      "pattern": "^([0-9]+(\\.[0-9]+)?(ns|us|ms|s|m|h))*([0-9]*[1-9][0-9]*(\\.[0-9]+)?|[0-9]+\\.[0-9]*[1-9][0-9]*)(ns|us|ms|s|m|h)([0-9]+(\\.[0-9]+)?(ns|us|ms|s|m|h))*$",
      "description": "A positive Go duration string (e.g. \"15m\", \"1h30m\")."
    },
    "goDurationNonNegative": {
      "type": "string",
      "pattern": "^(0|([0-9]+(\\.[0-9]+)?(ns|us|ms|s|m|h))+)$",
      "description": "A non-negative Go duration string: either the bare zero \"0\" or one or more unit terms (e.g. \"0m\", \"15m\", \"1h30m\"). Allows 0 for cooldownAfter (ADR-0004)."
    },
    "promDuration": {
      "type": "string",
      "pattern": "^([0-9]+(ms|s|m|h|d|w|y))+$",
      "description": "A Prometheus range/duration string (e.g. \"4h\", \"8d\")."
    },
    "alertTuning": {
      "type": "object",
      "properties": {
        "for": { "$ref": "#/definitions/promDuration" },
        "severity": { "type": "string", "minLength": 1 }
      }
    }
  }
}
