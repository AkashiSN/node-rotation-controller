{
  "name": "node-rotation-controller-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "predocs:dev": "node docs/.vitepress/scripts/build-wasm.mjs",
    "docs:dev": "vitepress dev docs",
    "predocs:build": "node docs/.vitepress/scripts/build-wasm.mjs",
    "docs:build": "vitepress build docs",
    "predocs:preview": "node docs/.vitepress/scripts/build-wasm.mjs",
    "docs:preview": "vitepress preview docs",
    "test:docs": "npm run test:docs:pure && npm run test:docs:dom",
    "test:docs:pure": "node --test docs/.vitepress/scripts/*.test.mjs docs/.vitepress/theme/components/simulator/*.test.ts",
    "test:docs:dom": "vitest run"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.6",
    "mermaid": "^11.4.1",
    "vitepress": "^1.6.3",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.1.10",
    "vue": "^3.5.13",
    "yaml": "^2.7.0"
  }
}
